# Per-tenant compose overrides stay LOCAL (do not leak customer handles to the public
# repo). Wildcard covers every docker-compose.<handle>.yml (customers + the staging
# canary) in one rule. The base composes that ARE meant to be public are negated back
# in just below so the wildcard can't accidentally ignore them.
docker-compose.*.yml
!docker-compose.yml
!docker-compose.override.yml
!docker-compose.app.yml
!docker-compose.rebaseltest.yml
docker-compose.ryushineo.yml

# =============================================================================
# Secret-leak hardening (added 2026-06-17 alongside the gitleaks gate)
# =============================================================================
# These are the categories that ACTUALLY leaked into this repo's history (see
# the 2026-06-17 code-health audit). Belt-and-suspenders with the gitleaks gate:
# the gate catches secret SHAPES; .gitignore stops the leak-prone FILE TYPES from
# ever being staged in the first place. ADD-only — nothing above is removed.

# SQL dumps / backups in general (history leaked full table dumps with app rows).
# The migrations stay tracked via the negation that follows.
*.sql
*backup*
!mcp-server/database/migrations/*.sql
# Manual down-migrations (e.g. rollback/046_*_ROLLBACK.sql) live in a subdir so the
# forward-migration runner (which scans migrations/ non-recursively) never auto-runs
# them; they are documented code, not data dumps — keep them tracked.
!mcp-server/database/migrations/rollback/*.sql
# Operator runbook SQL (gated, Ridge-run): parameterized DDL/DML, no table dumps /
# no app rows / no secrets — it's documented code that must ship (task bc819ae5).
!scripts/purge-deploy-smoke-sessions.sql
# ...but the backup/offsite SCRIPTS are code, not data dumps — keep them tracked
# (they read secrets at runtime, never embed them; the gitleaks gate enforces that).
!scripts/backup-*.sh
!scripts/offsite-*.sh

# Env files — block every variant, but ALWAYS keep the committed example.
.env
.env.*
!.env.example

# Logs (broaden beyond the specific names already ignored above).
*.log
logs/

# Local AI / scan scratch that captured secrets verbatim in history.
.surveyor/
ai-context/
debug-context*

# Captured auth/login responses (probe artifacts) — all variants.
auth_response*.json

docker-compose.sunbrolynk.yml

# Local backup snapshots (deploy/cutover .bak files) — disposable, never tracked.
*.bak
*.bak-*
