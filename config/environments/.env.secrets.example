# Mandrel Secrets Template
# =========================
# Copy this file to /opt/mandrel/.env.secrets on the VPS
# NEVER commit actual secrets to version control
#
# After copying, set secure permissions:
#   sudo chmod 600 /opt/mandrel/.env.secrets
#   sudo chown root:root /opt/mandrel/.env.secrets

# ============================================
# SINGLE SOURCE OF TRUTH
# ============================================
# Both services (mandrel.service / MCP and mandrel-command.service / backend)
# load THIS file via systemd EnvironmentFile. The DB password and JWT secret
# live here and ONLY here — do not duplicate them into mcp-server/.env,
# backend/.env, or .env.production.local. Rotate by editing this file and
# restarting both services. (See the secret-rotation runbook.)

# ============================================
# JWT AUTHENTICATION
# ============================================

# Canonical JWT key — what AuthService signs with AND what config validation
# requires. Generate with: openssl rand -hex 48
MANDREL_JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_VALUE

# ============================================
# DATABASE CREDENTIALS (single source of truth)
# ============================================

# Required in production. Connections are built from discrete fields (user/host/
# name/port live in the non-secret .env files); only the password lives here.
DATABASE_PASSWORD=REPLACE_WITH_DATABASE_PASSWORD

# ============================================
# API KEYS (for future use)
# ============================================

# Uncomment as needed for external service integrations
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# SENDGRID_API_KEY=SG....

# ============================================
# NOTES
# ============================================
#
# 1. This file is loaded via systemd's EnvironmentFile directive
# 2. Variables here are NOT visible in `systemctl show <service>`
# 3. Only root can read this file (chmod 600)
# 4. Rotate secrets by updating this file and restarting services
