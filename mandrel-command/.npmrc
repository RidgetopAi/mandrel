# Workspace-wide npm settings for the mandrel-command npm workspace.
#
# CRA react-scripts@5 declares a peerOptional typescript@^3||^4, but the frontend
# uses typescript@^5. That peer is only an optional hint; TS5 works with CRA5.
# legacy-peer-deps lets `npm ci -w mandrel-command-frontend` resolve deterministically
# from the workspace-root package-lock.json (in the Docker build and locally) without
# needing per-invocation --legacy-peer-deps flags. This MUST live at the workspace
# root because workspace-scoped installs run from here, not from frontend/.
legacy-peer-deps=true
