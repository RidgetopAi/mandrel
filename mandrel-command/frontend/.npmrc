# CRA react-scripts@5 declares a peerOptional typescript@^3||^4, but this app
# uses typescript@^5. That peer is only an optional hint; TS5 works with CRA5.
# legacy-peer-deps lets npm install / npm ci resolve deterministically here and
# in the Docker build (which runs `npm ci`) without --legacy-peer-deps flags.
legacy-peer-deps=true
